# =============================================================================
# cpet-safety-line-stage1 — Environment Configuration Example
# Copy this file to .env and fill in real values.
# .env is NEVER committed to version control.
# =============================================================================

# --------------- Data Paths ---------------
# Root directory containing the original CPET Excel files
DATA_DIR=/path/to/your/protected/data/directory

# Output directory for generated artifacts (default: ./outputs)
OUTPUT_DIR=./outputs

# Reports output directory (default: ./reports)
REPORTS_DIR=./reports

# --------------- Reproducibility ---------------
RANDOM_SEED=42

# --------------- Project Metadata ---------------
PROJECT_NAME=cpet-safety-line-stage1
STAGE=1

# --------------- Optional: MLflow Tracking ---------------
# Uncomment to enable experiment tracking
# MLFLOW_TRACKING_URI=./mlruns
# MLFLOW_EXPERIMENT_NAME=cpet_stage1

# --------------- Optional: Logging ---------------
LOG_LEVEL=INFO
# LOG_FILE=./logs/pipeline.log
